# LinkedIn session cookies (get from browser DevTools → Application → Cookies)
LINKEDIN_SESSION_COOKIE="your-li_at-cookie-value"
LINKEDIN_JSESSIONID="ajax:your-jsessionid-value"
# Optional: override LinkedIn API URL if default endpoint stops working
LINKEDIN_API_URL="https://www.linkedin.com/voyager/api/voyagerMessagingGraphQL/graphql?queryId=messengerConversations.0d5e6781bbee71c3e51c8843c6519f48&variables=(mailboxUrn:urn%3Ali%3Afsd_profile%3AACoAAAEsjJYBGY0OW9gSzxYg8Wv4z5zGf3sb9_0)""

# Docker Postgres (used by docker-compose.yml)
POSTGRES_DB="jobhelper"
